# ─── Backend Environment ─────────────────────────────────────
PORT=5000
NODE_ENV=production
PLAYWRIGHT_HEADLESS=true

# SQLite DB and uploads (inside container volumes)
DB_PATH=/app/data/jobscrapper.db
UPLOADS_PATH=/app/uploads

# ── CORS: Only allow your Vercel frontend URL ────────────────
# Set this to your actual Vercel deployment URL after deploying
ALLOWED_ORIGIN=https://your-app.vercel.app

# ── JWT Authentication ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string

# ── Dashboard Login ──────────────────────────────────────────
# Password to log into the React dashboard
DASHBOARD_PASSWORD=your_secure_password_here

# ── Cloudflare Tunnel ────────────────────────────────────────
# Get this from: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=

# ── Ngrok Alternative ────────────────────────────────────────
# NGROK_AUTHTOKEN=

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
# For Gmail: use App Password (not your real password)
# https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password
ALERT_EMAIL=your_email@gmail.com

# ── Polling ──────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=15
